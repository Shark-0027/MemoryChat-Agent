# =============================================================================
# MemoryChat-Agent - Environment Variables Example
# =============================================================================
# Copy this file to `.env` and fill in your real values.
#   cp .env.example .env
# NEVER commit the real `.env` file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI API Configuration
# -----------------------------------------------------------------------------
# Your OpenAI API key. Get it from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Base URL for OpenAI-compatible API endpoints.
# Use the default OpenAI endpoint or a custom proxy / compatible provider.
OPENAI_BASE_URL=https://api.openai.com/v1

# Chat completion model name.
OPENAI_MODEL=gpt-4o-mini

# Embedding model name used by mem0 for vector storage.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# mem0 Memory Configuration
# -----------------------------------------------------------------------------
# The vector store provider used by mem0 for long-term memory.
MEM0_VECTOR_STORE=chroma

# Local persistence path for ChromaDB.
MEM0_VECTOR_STORE_PATH=./data/chroma

# ChromaDB collection name.
MEM0_COLLECTION_NAME=mem0

# The LLM provider mem0 should use for memory extraction.
MEM0_LLM_PROVIDER=openai

# The embedder provider mem0 should use.
MEM0_EMBEDDER_PROVIDER=openai

# Default user identifier used to scope memories.
MEM0_DEFAULT_USER_ID=default_user

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# Application display name shown in the UI title and sidebar.
APP_NAME=MemoryChat-Agent

# Application version string shown in the UI.
APP_VERSION=0.1.0

# Streamlit server port.
APP_PORT=8501

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Whether to run the app in debug mode.
DEBUG=false
